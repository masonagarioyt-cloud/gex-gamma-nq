//@version=6
indicator("May Gamma & Gex Levels", overlay=true, max_lines_count=500, max_labels_count=500)

// ============================================================
// AUTO-GENERATED — 2026-07-21 13:22 UTC
// QQQ: from QQQ options, main expiry 2026-07-22, 0DTE 2026-07-21 | QQQ spot 696.06 -> QQQ spot 696.06
// NQ: from QQQ options, main expiry 2026-07-22, 0DTE 2026-07-21 | QQQ spot 696.06 -> NQ spot 29160.50
// SPY: from SPY options, main expiry 2026-07-22, 0DTE 2026-07-21 | SPY spot 742.09 -> SPY spot 742.09
// ES: from SPY options, main expiry 2026-07-22, 0DTE 2026-07-21 | SPY spot 742.09 -> ES spot 7514.00
// SPYonNQ: from SPY options, main expiry 2026-07-22, 0DTE 2026-07-21 | SPY spot 742.09 -> SPYonNQ spot 29160.50
// QQQonES: from QQQ options, main expiry 2026-07-22, 0DTE 2026-07-21 | QQQ spot 696.06 -> QQQonES spot 7514.00
// FREE-DATA ESTIMATE using the standard public GEX convention.
// NOT SpotGamma's or MenthorQ's proprietary model.
// "proj. on" levels are scaled projections for cross-asset
// comparison, not literal native prices.
// Paste this whole script over the old version each morning.
// ============================================================

labelSizeInput = input.string("Normal", "Labels Text Size", options=["Small", "Normal", "Large"], group="Display")
labelPosInput = input.string("Above", "Label Position", options=["Above", "Below", "Left", "Right"], group="Display")
offsetBars = input.int(3, "Left/Right Offset (bars)", minval=0, maxval=200, group="Display")
showPctInput = input.bool(true, "Show % on labels", group="Display")
mergeWithinInput = input.float(15.0, "Merge levels within (pts)", minval=0.0, tooltip="When two levels land within this many points of each other, only the higher-priority one is shown. Set to 0 to show every level.", group="Display")
lineWidthInput = input.int(3, "Line Width", minval=1, maxval=6, group="Display")

f_labelSize(s) =>
    s == "Small" ? size.small : s == "Large" ? size.large : size.normal
f_labelStyle(p) =>
    p == "Below" ? label.style_label_up : p == "Left" ? label.style_label_right : p == "Right" ? label.style_label_left : label.style_label_down
resolvedSize = f_labelSize(labelSizeInput)
resolvedStyle = f_labelStyle(labelPosInput)

alertsEnabledInput = input.bool(false, "Enable Alerts", tooltip="Master switch. Turn on, then set up a TradingView alert on this indicator with condition \"Any alert() function call\" to get pinged.", group="Alerts")
alertCallWallInput = input.bool(true, "Alert on Call Wall / Resistance crosses", group="Alerts")
alertPutWallInput = input.bool(true, "Alert on Put Wall / Support crosses", group="Alerts")
alertGammaFlipInput = input.bool(true, "Alert on Gamma Flip crosses", group="Alerts")
alertOtherInput = input.bool(false, "Alert on other levels (GEX ranks, Gamma Wall, Expected Move, etc.)", group="Alerts")

autoDetectInput = input.bool(true, "Auto-detect chart symbol", tooltip="ON by default: automatically shows the level pair that matches your current chart scale (e.g. NQ + SPY-proj.-on-NQ on an NQ chart, ES + QQQ-proj.-on-ES on an ES chart). Turn OFF to control visibility fully with the toggles below instead.", group="Source Visibility")
showSource_QQQ = input.bool(true, "Show QQQ Levels", group="Source Visibility")
matchSym_QQQ = str.contains(syminfo.ticker, "QQQ") or str.contains(syminfo.root, "QQQ")
effectiveShow_QQQ = showSource_QQQ and (not autoDetectInput or matchSym_QQQ)
showSource_NQ = input.bool(true, "Show NQ Levels", group="Source Visibility")
matchSym_NQ = str.contains(syminfo.ticker, "NQ") or str.contains(syminfo.root, "NQ")
effectiveShow_NQ = showSource_NQ and (not autoDetectInput or matchSym_NQ)
showSource_SPY = input.bool(true, "Show SPY Levels", group="Source Visibility")
matchSym_SPY = str.contains(syminfo.ticker, "SPY") or str.contains(syminfo.root, "SPY")
effectiveShow_SPY = showSource_SPY and (not autoDetectInput or matchSym_SPY)
showSource_ES = input.bool(true, "Show ES Levels", group="Source Visibility")
matchSym_ES = str.contains(syminfo.ticker, "ES") or str.contains(syminfo.root, "ES")
effectiveShow_ES = showSource_ES and (not autoDetectInput or matchSym_ES)
showSource_SPYonNQ = input.bool(true, "Show SPY proj. on NQ Levels", group="Source Visibility")
matchSym_SPYonNQ = str.contains(syminfo.ticker, "NQ") or str.contains(syminfo.root, "NQ")
effectiveShow_SPYonNQ = showSource_SPYonNQ and (not autoDetectInput or matchSym_SPYonNQ)
showSource_QQQonES = input.bool(true, "Show QQQ proj. on ES Levels", group="Source Visibility")
matchSym_QQQonES = str.contains(syminfo.ticker, "ES") or str.contains(syminfo.root, "ES")
effectiveShow_QQQonES = showSource_QQQonES and (not autoDetectInput or matchSym_QQQonES)

show_lvl0 = input.bool(true, "Call Wall (QQQ)", group="Level Filters", inline="row_lvl0", tooltip="Strike with the largest positive gamma exposure. Often acts like resistance.")
col_lvl0 = input.color(color.green, "", group="Level Filters", inline="row_lvl0")
show_lvl1 = input.bool(true, "Put Wall (QQQ)", group="Level Filters", inline="row_lvl1", tooltip="Strike with the largest negative gamma exposure. Often acts like support.")
