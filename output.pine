var float[] activePrices = array.new_float(0)
if barstate.islast
    array.clear(activePrices)
    for i = 0 to array.size(allPrices) - 1
        line.delete(array.get(allLines, i))
        label.delete(array.get(allLabels, i))
        p = array.get(allPrices, i)
        tooClose = false
        if mergeWithinInput > 0 and array.size(activePrices) > 0
            for j = 0 to array.size(activePrices) - 1
                if math.abs(p - array.get(activePrices, j)) <= mergeWithinInput
                    tooClose := true
        if array.get(allShow, i) and not tooClose
            array.push(activePrices, p)
            c = array.get(allColors, i)
            newLine = line.new(bar_index - 10, p, bar_index, p, color=c, width=lineWidthInput, extend=extend.both)
            array.set(allLines, i, newLine)
            newLabel = label.new(bar_index + offsetBars, p, array.get(allTexts, i), xloc=xloc.bar_index, style=resolvedStyle, color=color.new(color.black, 100), textcolor=c, size=resolvedSize)
            array.set(allLabels, i, newLabel)

if alertsEnabledInput
    for i = 0 to array.size(allPrices) - 1
        if array.get(allShow, i)
            p = array.get(allPrices, i)
            crossedUp = close > p and close[1] <= p
            crossedDown = close < p and close[1] >= p
            if crossedUp or crossedDown
                cat = array.get(allCategories, i)
                wantAlert = (cat == "CallWall" and alertCallWallInput) or (cat == "PutWall" and alertPutWallInput) or (cat == "GammaFlip" and alertGammaFlipInput) or (cat == "Other" and alertOtherInput)
                if wantAlert
                    dirText = crossedUp ? "crossed ABOVE" : "crossed BELOW"
                    alert(array.get(allTexts, i) + " " + dirText + " (" + str.tostring(p, format.mintick) + ")", alert.freq_once_per_bar)

var label freshLabel = na
if barstate.islast
    label.delete(freshLabel)
    freshLabel := label.new(bar_index, high, "Data as of 2026-07-21 13:22 UTC", xloc=xloc.bar_index, yloc=yloc.abovebar, style=label.style_label_down, color=color.new(color.gray, 70), textcolor=color.white, size=size.tiny)
