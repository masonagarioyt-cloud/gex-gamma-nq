var float[] activePrices = array.new_float(0)
if barstate.islast
    array.clear(activePrices)
    for i = 0 to array.size(allPrices) - 1
        line.delete(array.get(allLines, i))
        label.delete(array.get(allLabels, i))
        p = array.get(allPrices, i)
        tooClose = false
        if mergeWithinInput > 0 and array.size(activePrices) > 0
            for j = 0 to array.size(activePrices) - 1
                if math.abs(p - array.get(activePrices, j)) <= mergeWithinInput
                    tooClose := true
        if array.get(allShow, i) and not tooClose
            array.push(activePrices, p)
            c = array.get(allColors, i)
            newLine = line.new(bar_index - 10, p, bar_index, p, color=c, width=lineWidthInput, extend=extend.both)
            array.set(allLines, i, newLine)
            newLabel = label.new(bar_index + offsetBars, p, array.get(allTexts, i), xloc=xloc.bar_index, style=resolvedStyle, color=color.new(color.black, 100), textcolor=c, size=resolvedSize)
            array.set(allLabels, i, newLabel)
