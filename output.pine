//@version=6
indicator("NQ GEX Levels (Auto-Generated, Free Data Estimate)", overlay=true, max_lines_count=100, max_labels_count=100)

// ============================================================
// AUTO-GENERATED — 2026-07-16 23:20 UTC
// Source: QQQ options chain (free/unofficial). Main expiry: 2026-07-17, 0DTE: 2026-07-16
// QQQ spot at calc time: 705.94 | NQ spot at calc time: 29113.50
// FREE-DATA ESTIMATE using the standard public GEX convention
// (dealers long calls / short puts). NOT SpotGamma's or
// MenthorQ's proprietary model. "Strength %" = this level's
// magnitude relative to the single strongest strike found.
// Paste this whole script over the old version each morning.
// ============================================================

labelSizeInput = input.string("Normal", "Labels Text Size", options=["Small", "Normal", "Large"], group="Display")
labelPosInput = input.string("Above", "Label Position", options=["Above", "Below", "Left", "Right"], group="Display")
offsetBars = input.int(3, "Left/Right Offset (bars)", minval=0, maxval=200, group="Display")
showPctInput = input.bool(true, "Show % on labels", group="Display")
mergeWithinInput = input.float(15.0, "Merge levels within (pts)", minval=0.0, tooltip="When two levels land within this many points of each other, only the higher-priority one is shown, to reduce clutter. Set to 0 to show every level.", group="Display")
lineWidthInput = input.int(3, "Line Width", minval=1, maxval=6, group="Display")

f_labelSize(s) =>
    s == "Small" ? size.small : s == "Large" ? size.large : size.normal
f_labelStyle(p) =>
    p == "Below" ? label.style_label_up : p == "Left" ? label.style_label_right : p == "Right" ? label.style_label_left : label.style_label_down
resolvedSize = f_labelSize(labelSizeInput)
resolvedStyle = f_labelStyle(labelPosInput)

show_lvl0 = input.bool(true, "Call Wall", group="Level Filters", tooltip="Strike with the largest positive gamma exposure. Often acts like resistance - price stalling or reversing down here is common.")
show_lvl1 = input.bool(true, "Put Wall", group="Level Filters", tooltip="Strike with the largest negative gamma exposure. Often acts like support - price stalling or reversing up here is common.")
show_lvl2 = input.bool(true, "Gamma Flip", group="Level Filters", tooltip="The price where dealer hedging flips character. Below it, hedging tends to amplify moves (more volatile). Above it, hedging tends to dampen moves (more range-bound). A regime marker, not a wall.")
show_lvl3 = input.bool(true, "Gamma Wall", group="Level Filters", tooltip="Strike with the single largest TOTAL gamma exposure (calls + puts combined) - the biggest overall hedging pressure point, regardless of direction.")
show_lvl4 = input.bool(true, "Call Resistance (OI)", group="Level Filters", tooltip="Strike with the most open call contracts outstanding. A raw positioning measure, separate from gamma exposure.")
show_lvl5 = input.bool(true, "Put Support (OI)", group="Level Filters", tooltip="Strike with the most open put contracts outstanding. A raw positioning measure, separate from gamma exposure.")
show_lvl6 = input.bool(true, "Call Resistance 0DTE", group="Level Filters", tooltip="Same concept as Call Wall, but calculated using only options expiring today (0DTE).")
show_lvl7 = input.bool(true, "Put Support 0DTE", group="Level Filters", tooltip="Same concept as Put Wall, but calculated using only options expiring today (0DTE).")
show_lvl8 = input.bool(true, "Gamma Wall 0DTE", group="Level Filters", tooltip="Strike with the single largest TOTAL gamma exposure (calls + puts combined) - the biggest overall hedging pressure point, regardless of direction. Calculated using only today's expiring options.")
show_lvl9 = input.bool(true, "Call Resistance 0DTE (OI)", group="Level Filters", tooltip="Strike with the most open call contracts outstanding. A raw positioning measure, separate from gamma exposure. Today's expiry only.")
show_lvl10 = input.bool(true, "Put Support 0DTE (OI)", group="Level Filters", tooltip="Strike with the most open put contracts outstanding. A raw positioning measure, separate from gamma exposure. Today's expiry only.")
show_lvl11 = input.bool(true, "GEX 1", group="GEX Filters", tooltip="A strong gamma-exposure strike, ranked by magnitude (not necessarily the single strongest - see the number).")
